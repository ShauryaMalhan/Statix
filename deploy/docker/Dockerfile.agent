# FinOps eBPF Node Agent (finops-user) — production multi-stage image.
# Requires privileged/root at runtime (CAP_BPF, cgroup reads).
# Build from repo root (finops-core):
#   docker build -f deploy/docker/Dockerfile.agent -t finops-agent:latest .

FROM rust:1.85-bookworm AS builder

WORKDIR /usr/src/finops

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        clang llvm libelf-dev zlib1g-dev pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# eBPF: nightly + bpf-linker + bpfel-unknown-none (finops-ebpf is outside the workspace)
RUN rustup toolchain install nightly --profile minimal \
    && rustup component add rust-src --toolchain nightly \
    && cargo install bpf-linker

COPY . .

# Three ring-buffer tiers → target/bpf/ (same as `make build-ebpf`)
RUN set -eux; \
    mkdir -p target/bpf; \
    cd finops-ebpf; \
    for pair in finops-ebpf-small:524288 finops-ebpf-large:4194304 finops-ebpf-xlarge:8388608; do \
        name="${pair%%:*}"; bytes="${pair##*:}"; \
        echo "Building $name ($bytes bytes)"; \
        FINOPS_RING_BUF_BYTES="$bytes" cargo +nightly build --release \
            -Z build-std=core --target bpfel-unknown-none; \
        cp target/bpfel-unknown-none/release/finops-ebpf "../target/bpf/${name}"; \
    done; \
    cd ..; \
    cargo build --release -p finops-user

FROM debian:bookworm-slim

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Agent must run as root (or CAP_BPF + CAP_PERFMON + CAP_SYS_ADMIN) to load BPF.
COPY --from=builder /usr/src/finops/target/release/finops-user /usr/local/bin/finops-agent
COPY --from=builder /usr/src/finops/target/bpf /app/bpf

ENV RUST_LOG=info
ENV FINOPS_BPF_DIR=/app/bpf

ENTRYPOINT ["finops-agent"]
