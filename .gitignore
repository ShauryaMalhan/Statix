# ============================================================
# FinOps eBPF Agent вЂ” .gitignore
# ============================================================

# в”Ђв”Ђ Rust build artifacts в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# The workspace target directory (statix-common, statix, statix-gateway).
# Includes bundled eBPF ELFs from `make build-ebpf` в†’ target/bpf/
/target/

# statix-ebpf has its own target directory because it is excluded
# from the workspace (different compilation target: bpfel-unknown-none)
/statix-ebpf/target/

# NOTE: Cargo.lock files ARE committed.
# For binary crates (finops-user) this guarantees reproducible builds.
# Do NOT add Cargo.lock here.

# в”Ђв”Ђ eBPF compiled bytecode в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Raw object files produced by clang or llvm if ever generated manually
*.bpf.o
*.bpf.elf

# в”Ђв”Ђ Environment and secrets в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
.env
.env.*
!.env.example
*.env
secrets/
config.local.toml

# Private keys and certificates вЂ” never commit these
*.pem
*.key
*.crt
*.p12
*.pfx

# в”Ђв”Ђ Editor and IDE artifacts в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# VSCode / Cursor workspace settings (machine-specific, not shared config)
.vscode/
# Cursor local state вЂ” ignore; keep shared agent skills tracked
.cursor/*
!.cursor/skills/
!.cursor/skills/**

# JetBrains IDEs
.idea/
*.iml

# Vim / Neovim swap and backup files
*.swp
*.swo
*.swn
*~

# Emacs backup files
\#*\#
.\#*

